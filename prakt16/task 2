ID_allowed = input("Введите разрешенные ID: ")

ID_allowed_set = {int(x) for x in ID_allowed.split()}


ID_incoming = input("Введите новые ID: ")

ID_incoming_list = [int(x) for x in ID_incoming.split()]


for ID in ID_incoming_list:

    if ID in ID_allowed_set:
        print(ID, "OK")

    else:

        print(ID, "ADDED")
        ID_allowed_set.add(ID)

print(ID_allowed_set)
