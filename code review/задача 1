# должен быть int
n = int(input("Введите натуральное число: "))


# та же формула в if
# product = n % 10

if n >= 10:
    digit = n % 10
    
    # продукт в формуле должен быть n
    product = n * digit
    
    # n //= 10 # не подходит
    
    print(product)
# небыло else

else:
    
    print("цифра меньше 10")
